{
  "name": "@hawksearch/vue",
  "version": "1.0.1",
  "description": "Vue.js SDK for Hawksearch",
  "module": "dist/vue-hawksearch.js",
  "scripts": {
    "in": "npm i",
    "gv": "genversion src/version.js --esm",
    "release": "npm run gv && npm run build",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "dev": "npm run create:index && vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run build:watch\"",
    "dev:prod": "vite --mode production",
    "dev:stg": "vite --mode staging",
    "preview": "npm run create:index && vite build --config vite.preview.config.js && cp hs.config.js preview && vite --config vite.preview.config.js preview",
    "create:index": "node src/generatePreviewIndex.js",
    "clean:d": "rm -rf dist",
    "clean:c": "npm cache clean --force",
    "clean:index": "rm -rf index.html",
    "clean:node": "rm -rf node_modules package-lock.json preview",
    "clean:all": "npm run clean:node && npm run clean:c && npm run clean:index"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hawksearch/vue-hawksearch.git"
  },
  "author": "Hawksearch",
  "license": "Apache-2.0",
  "licenses": [
    {
      "type": "Apache-2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0"
    }
  ],
  "homepage": "https://github.com/hawksearch/vue-hawksearch",
  "dependencies": {
    "axios": "^1.7.9",
    "change-case": "^5.4.4",
    "lodash": "^4.17.21",
    "moment-mini": "^2.29.4",
    "vue": "^3.2.45",
    "vue-i18n": "^11.1.1",
    "vuex": "^4.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-arrow-functions": "^7.25.9",
    "@babel/plugin-transform-class-properties": "^7.25.9",
    "@babel/plugin-transform-destructuring": "^7.25.9",
    "@babel/plugin-transform-object-rest-spread": "^7.25.9",
    "@babel/preset-env": "^7.26.9",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@vitejs/plugin-vue": "^4.0.0",
    "history": "^5.3.0",
    "sass": "^1.85.1",
    "terser": "^5.39.0",
    "vite": "^4.0.0",
    "concurrently": "^9.2.1"
  }
}
